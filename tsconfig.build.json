{
  // Declarations-only build for the wevm-style packaging: tsc emits only
  // `.d.ts` (+ maps) into `_types/`. Runtime JS is emitted by rollup
  // (rollup.config.mjs) into `_esm/` and `_cjs/`.
  "extends": "./tsconfig.base.json",
  "include": ["src"],
  "exclude": [
    "src/**/*.bench.ts",
    "src/**/*.bench-d.ts",
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec-d.ts",
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "_types",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true
  }
}
