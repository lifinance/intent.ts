{
  "name": "@lifi/intent",
  "private": false,
  "version": "0.2.0",
  "description": "Typescript library for OIF and LI.FI Intent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifinance/intent.ts.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./_cjs/index.js",
  "module": "./_esm/index.js",
  "types": "./_types/index.d.ts",
  "typings": "./_types/index.d.ts",
  "files": [
    "_cjs",
    "_esm",
    "_types",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.bench.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./_types/index.d.ts",
      "node": "./_cjs/index.js",
      "import": "./_esm/index.js",
      "require": "./_cjs/index.js",
      "default": "./_cjs/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf _cjs _esm _types dist out",
    "prebuild": "bun run clean",
    "build:js": "rollup -c",
    "build:types": "tsc --project tsconfig.build.json",
    "build:markers": "node ./scripts/write-subdir-markers.mjs",
    "build:smoke": "node ./scripts/smoke.mjs",
    "build": "bun run build:js && bun run build:types && bun run build:markers && bun run build:smoke",
    "lint:staged": "prettier -w",
    "prepublishOnly": "bun run build && bun run check && bun run test",
    "test": "bun test",
    "check": "tsc --noEmit -p tsconfig.json",
    "coverage": "bun run test --coverage",
    "coverage:lcov": "bun run coverage --coverage-reporter='lcov' --coverage-dir='./'"
  },
  "lint-staged": {
    "*.ts": [
      "bun run lint:staged"
    ]
  },
  "dependencies": {
    "borsh": "^2.0.0",
    "ky": "^1.12.0",
    "viem": "~2.45.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "bun": "^1.3.5",
    "husky": "9.1.7",
    "lint-staged": "16.1.0",
    "prettier": "3.4.2",
    "rollup": "^4.61.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.6.3"
  }
}
